# Copy this file to .env.local and fill in your own values.
# Get these from your Supabase project: Settings -> API

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # keep this SECRET, never share or commit it

# Password for /admin/login — choose your own strong password
ADMIN_PASSWORD=change-this-password
